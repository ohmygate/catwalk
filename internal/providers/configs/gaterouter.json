{
  "name": "GateRouter",
  "id": "gaterouter",
  "api_key": "$GATEROUTER_API_KEY",
  "api_endpoint": "https://api.gaterouter.ai/openai/v1",
  "type": "openai-compat",
  "default_large_model_id": "auto",
